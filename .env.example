# MySQL (PlanetScale, Railway, local — qualquer host MySQL serve)
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:senha@localhost:3306/devjunior"

# Auth (cadastro aberto, mas só admins acessam /painel)
# AUTH_SECRET: 32+ bytes aleatórios (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET="troque-isso-por-um-secret-aleatorio-de-no-minimo-32-bytes"

# E-mails (separados por vírgula) que viram admin automático ao cadastrar/logar
ADMIN_EMAILS="seu@email.com"
