# =============================================================
# Dev Junior — exemplo de .env
# Copie para `.env` e preencha os valores reais.
# =============================================================

# --- Banco -----------------------------------------------------
# MySQL (Railway, PlanetScale, local — qualquer host MySQL serve).
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:senha@localhost:3306/devjunior"

# --- Auth ------------------------------------------------------
# 32+ bytes aleatórios. Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="troque-isso-por-um-secret-aleatorio-de-no-minimo-32-bytes"

# E-mails (separados por vírgula) que viram admin automaticamente ao cadastrar/logar.
ADMIN_EMAILS="seu@email.com"

# --- SEO / URLs ------------------------------------------------
# URL pública do site (sem barra no final). Usada para canonical, OG e sitemap.
# Em dev pode ficar vazio que cai pra http://localhost:3000.
NEXT_PUBLIC_SITE_URL="https://seu-dominio.vercel.app"

# --- Firebase Storage (opcional, só pra upload de capas) -------
# Crie um service account em: Firebase Console → Configurações → Contas de Serviço.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Mantém os \n literais — o código converte para quebra de linha real.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET="seu-projeto.firebasestorage.app"
